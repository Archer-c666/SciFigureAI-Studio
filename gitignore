# =========================================================
# SciFigure AI Studio - Git Ignore
# 目的：避免提交临时文件、缓存、虚拟环境、打包产物、API Key 和本地配置
# =========================================================

# -------------------------
# Python cache / bytecode
# -------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# -------------------------
# Virtual environments
# -------------------------
.venv/
venv/
env/
ENV/
.python-version

# -------------------------
# Local environment / secrets
# 不要提交 API Key、Token、本地模型配置
# -------------------------
.env
.env.*
!.env.example
*.env
secrets.*
*.key
*.pem
*.crt
*.p12
*.pfx

# 本地配置文件：保留示例配置，忽略个人配置
config.local.py
config.private.py
settings.local.py
settings.private.py
local_config.py
local_settings.py
*.local.json
*.local.yaml
*.local.yml
*.private.json
*.private.yaml
*.private.yml

# 如果你把大模型配置保存成这些文件，也不要提交
llm_config.json
llm_config.yaml
llm_config.yml
api_config.json
api_config.yaml
api_config.yml
user_config.json
user_settings.json

# -------------------------
# Logs
# -------------------------
*.log
logs/
pandasai.log

# -------------------------
# Build / packaging outputs
# PyInstaller / setuptools / wheel
# -------------------------
build/
dist/
*.spec.bak
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/

# PyInstaller runtime cache
*.manifest
*.toc
*.pkg
*.pyz
*.pyz_extracted/

